              "id": "condition-agent-handling",
              "leftValue": "={{ $json.agentHandling }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
