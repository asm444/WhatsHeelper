        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $json.body.payload.body }}\",\n  \"phone\": \"{{ $json.body.payload.from }}\",\n  \"conversationHistory\": []\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "classify-message",
      "name": "Classificar Mensagem",
