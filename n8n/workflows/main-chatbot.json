      "parameters": {
        "method": "POST",
        "url": "http://amaral-business-engine:3002/escalate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"phone\": \"{{ $('WAHA Webhook').item.json.body.payload.from }}\",\n  \"category\": \"{{ $json.category }}\",\n  \"messages\": [\"Cliente: {{ $('WAHA Webhook').item.json.body.payload.body }}\"],\n  \"reason\": \"{{ $json.escalation.reason }}\",\n  \"priority\": \"{{ $json.escalation.priority }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "escalate-ticket",
      "name": "Escalar para Atendente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1350, 620]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://amaral-chat-simulator:3001/api/sendText",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"chatId\": \"{{ $('WAHA Webhook').item.json.body.payload.from }}\",\n  \"text\": \"{{ $json.response }}\",\n  \"session\": \"default\"\n}",
        "options": {}
      },
      "id": "send-response",
      "name": "Enviar Resposta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1570, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://amaral-chat-simulator:3001/api/sendText",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"chatId\": \"{{ $('WAHA Webhook').item.json.body.payload.from }}\",\n  \"text\": \"Entendo que você precisa de ajuda especializada. Estou transferindo você para um de nossos atendentes. Por favor, aguarde um momento. 🙏\",\n  \"session\": \"default\"\n}",
        "options": {}
      },
      "id": "send-escalation-msg",
      "name": "Avisar Escalação",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1570, 620]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={\"status\": \"ok\"}",
        "options": {
          "responseCode": 200
        }
      },
      "id": "respond-ok",
      "name": "Responder 200",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1790, 500]
    }
