        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": \"{{ $('WAHA Webhook').item.json.body.payload.body }}\",\n  \"category\": \"{{ $json.category }}\",\n  \"conversationHistory\": []\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "generate-response",
      "name": "Gerar Resposta",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
